<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.survivalwiki">

    <application
        android:name=".SurvivalWikiApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher_orange"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round_orange"
        android:supportsRtl="true"
        android:theme="@style/Theme.SurvivalWiki.Starting.Orange">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.SurvivalWiki.Starting.Orange" />

        <activity-alias
            android:name=".LauncherOrange"
            android:targetActivity=".MainActivity"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_orange"
            android:roundIcon="@mipmap/ic_launcher_round_orange"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".LauncherOlive"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_olive"
            android:roundIcon="@mipmap/ic_launcher_round_olive"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".LauncherBlue"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_blue"
            android:roundIcon="@mipmap/ic_launcher_round_blue"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
    </application>

</manifest>
